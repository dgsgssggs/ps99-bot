# ============================================================
# .env.example — Configuración del bot PS99
# ============================================================
# Copia como ".env" y rellena los valores.
# En Railway, añade estas variables en el panel de Variables.
# NUNCA subas el .env a GitHub.
# ============================================================

# ── Token del bot de Discord ──────────────────────────────────
# Obtén el token en: discord.com/developers/applications → Bot
DISCORD_TOKEN=TU_TOKEN_AQUI

# ── Owners (control total del bot) ───────────────────────────
# Pueden usar TODOS los comandos de admin.
# Separa múltiples IDs con comas: 123456,789012
OWNER_IDS=TU_ID_AQUI

# ── Admins (pueden crear códigos y gestionar) ─────────────────
# Pueden usar /code create, /code delete, /code list.
# Separa múltiples IDs con comas: 111111,222222
# Deja vacío si no quieres admins adicionales.
ADMIN_IDS=

# ── Compatibilidad con versiones anteriores ───────────────────
# Si tenías OWNER_ID (sin S), sigue funcionando automáticamente.
# OWNER_ID=TU_ID_AQUI

# ── Crypto (depósitos SOL y LTC) ─────────────────────────────
# Helius API — gratis en helius.dev (para detectar txs de Solana)
HELIUS_API_KEY=TU_HELIUS_KEY_AQUI

# BlockCypher — gratis en blockcypher.com (para wallets y txs de LTC)
# Sin token funciona igual pero con límite más bajo
BLOCKCYPHER_TOKEN=TU_BLOCKCYPHER_TOKEN_AQUI

# Cuántas gemas vale 1 USD (configurable también con /setgemrate)
GEMS_PER_USD=1000000

# ── Hot Wallets (donde recibes el crypto) ────────────────────
# Tu wallet de Phantom / Solflare para recibir SOL
HOT_WALLET_SOL=TU_WALLET_SOLANA_AQUI

# Tu wallet de Litecoin para recibir LTC  
HOT_WALLET_LTC=TU_WALLET_LITECOIN_AQUI
